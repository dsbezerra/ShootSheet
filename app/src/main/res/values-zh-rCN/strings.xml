    <!-- Tooltips -->
    <string name="tooltip_aperture_title">光圈（f 值）</string>
    <string name="tooltip_aperture_body">控制景深和进光量。小 f 值（f/1.4）= 大光圈 = 浅景深 + 更多光。大 f 值（f/16）= 小光圈 = 深景深 + 更少光。</string>
    <string name="tooltip_shutter_title">快门速度</string>
    <string name="tooltip_shutter_body">传感器曝光时间。高速（1/1000s）可凝固动作。低速（1/30s）可产生动感模糊。低于 1/60s 手持拍摄会导致抖动——请使用三脚架。</string>
    <string name="tooltip_iso_title">ISO 感光度</string>
    <string name="tooltip_iso_body">放大传感器信号。ISO 100 = 干净、无噪点。ISO 6400+ = 明亮但有噪点/颗粒感。始终使用场景允许的最低 ISO。</string>
    <string name="tooltip_wb_title">白平衡</string>
    <string name="tooltip_wb_body">调整色温以使白色呈现中性。\"阴天\" 使画面偏暖（约 6500K）。\"钨丝灯\" 使画面偏冷（约 3200K）。拍摄 RAW 格式可在后期修改。</string>
    <string name="tooltip_focus_title">对焦模式</string>
    <string name="tooltip_focus_body">单次 AF（AF-S）：半按快门时锁定对焦——适合静止主体。连续 AF（AF-C）：持续追踪移动主体。手动：精确控制对焦。</string>

    <!-- Scenarios -->
    <string name="scenario_golden_hour_title">黄金时刻人像</string>
    <string name="scenario_golden_hour_subtitle">日出/日落时温暖迷人的光线</string>
    <string name="scenario_golden_hour_tip">将主体放在太阳前方，制造自然的轮廓光。使用反光板补充阴影部分。</string>

    <string name="scenario_indoor_natural_title">室内自然光</string>
    <string name="scenario_indoor_natural_subtitle">窗光人像拍摄</string>
    <string name="scenario_indoor_natural_tip">将主体与窗户呈 45° 角（伦勃朗光）。关掉所有人工光源以获得干净的色彩。</string>

    <string name="scenario_studio_portrait_title">棚拍人像</string>
    <string name="scenario_studio_portrait_subtitle">可控的灯光布置</string>
    <string name="scenario_studio_portrait_tip">快门速度需低于闪光同步速度（通常为 1/200）。从 ISO 100 开始，调整闪光灯功率。</string>

    <string name="scenario_blue_hour_title">蓝调时刻风景</string>
    <string name="scenario_blue_hour_subtitle">日落后 20–40 分钟的魔幻时刻</string>
    <string name="scenario_blue_hour_tip">使用三脚架和遥控快门。钨丝灯白平衡可增强蓝色调，营造忧郁氛围。</string>

    <string name="scenario_waterfall_title">丝滑瀑布</string>
    <string name="scenario_waterfall_subtitle">长曝光捕捉流水动感</string>
    <string name="scenario_waterfall_tip">光线较强时使用 ND 滤镜。1–2 秒曝光可呈现"棉花糖"般的丝滑效果。</string>

    <string name="scenario_golden_landscape_title">黄金时刻风景</string>
    <string name="scenario_golden_landscape_subtitle">地形上戏剧性的暖光</string>
    <string name="scenario_golden_landscape_tip">提前 30 分钟到达。提前勘景——光线几分钟内就会变化。</string>

    <string name="scenario_freeze_motion_title">凝固高速动作</string>
    <string name="scenario_freeze_motion_subtitle">清晰的动作抓拍</string>
    <string name="scenario_freeze_motion_tip">使用连拍模式并跟踪移动主体。AI 追踪对焦在这里效果显著。</string>

    <string name="scenario_panning_title">追焦模糊</string>
    <string name="scenario_panning_subtitle">主体清晰、背景动感模糊</string>
    <string name="scenario_panning_tip">平稳跟随主体并在运动中按下快门。需要多加练习——连拍拍摄。</string>

    <string name="scenario_sports_outdoor_title">户外运动</string>
    <string name="scenario_sports_outdoor_subtitle">白天的场地运动拍摄</string>
    <string name="scenario_sports_outdoor_tip">选择背光位置拍摄。使用长焦镜头（200–600mm）实现紧凑构图。</string>

    <string name="scenario_milky_way_title">银河</string>
    <string name="scenario_milky_way_subtitle">晴朗夜晚的银河核心</string>
    <string name="scenario_milky_way_tip">使用「500 法则」——500 除以焦距 = 出现星轨前的最大曝光秒数。</string>

    <string name="scenario_city_night_title">城市夜景</string>
    <string name="scenario_city_night_subtitle">城市夜景与光轨</string>
    <string name="scenario_city_night_tip">等待民用薄暮——日落约 20 分钟后，城市灯光与蓝天达到最美平衡。</string>

    <string name="scenario_light_painting_title">光绘</string>
    <string name="scenario_light_painting_subtitle">用光工具进行创意长曝光</string>
    <string name="scenario_light_painting_tip">穿深色衣服以避免出现在画面中。使用小手电筒进行精细描绘。</string>

    <string name="scenario_wedding_reception_title">婚礼宴会</string>
    <string name="scenario_wedding_reception_subtitle">室内混合光线活动</string>
    <string name="scenario_wedding_reception_tip">将闪光灯弹射到天花板以获得自然的补光效果。拍摄 RAW——混合光线在机内难以修正。</string>

    <string name="scenario_concert_title">演唱会与现场音乐</string>
    <string name="scenario_concert_subtitle">舞台灯光、动作迅速的表演者</string>
    <string name="scenario_concert_tip">大多数场馆只允许在前 3 首歌时拍摄。在彩排时观察灯光布置。</string>

    <string name="scenario_corporate_title">企业活动</string>
    <string name="scenario_corporate_subtitle">会议、证件照、圆桌论坛</string>
    <string name="scenario_corporate_tip">快速交付照片——客户通常当天就需要发布社交媒体。在现场积极筛选照片。</string>

    <string name="scenario_sunny_street_title">晴天街拍</string>
    <string name="scenario_sunny_street_subtitle">明亮城市日光下的拍摄</string>
    <string name="scenario_sunny_street_tip">晴天 16 法则：晴天时 f/16 下快门速度 = 1/ISO。使用「区域对焦」进行腰平拍摄。</string>

    <string name="scenario_rainy_street_title">雨天街拍</string>
    <string name="scenario_rainy_street_subtitle">水面倒影与阴郁湿润的场景</string>
    <string name="scenario_rainy_street_tip">低角度拍摄以捕捉水坑中的倒影。阴天光线自然柔和——非常适合街拍色彩。</string>

    <string name="scenario_night_street_title">夜间街拍</string>
    <string name="scenario_night_street_subtitle">霓虹招牌、酒吧与深夜都市生活</string>
    <string name="scenario_night_street_tip">拥抱颗粒感。夜间高 ISO 噪点具有电影质感——向高光曝光，而非阴影。</string>

