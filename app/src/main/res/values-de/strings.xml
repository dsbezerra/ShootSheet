    <!-- Tooltips -->
    <string name="tooltip_aperture_title">Blende (f-Stop)</string>
    <string name="tooltip_aperture_body">Kontrolliert Schärfentiefe und Lichteinfall. Kleine f-Werte (f/1.4) = weit offen = geringe Schärfentiefe + mehr Licht. Große Werte (f/16) = kleine Öffnung = große Schärfentiefe + weniger Licht.</string>
    <string name="tooltip_shutter_title">Verschlusszeit</string>
    <string name="tooltip_shutter_body">Wie lange der Sensor belichtet wird. Kurze Zeiten (1/1000s) frieren Bewegung ein. Lange Zeiten (1/30s) erzeugen Bewegungsunschärfe. Unter 1/60s aus der Hand führt zu Verwacklung — Stativ verwenden.</string>
    <string name="tooltip_iso_title">ISO-Empfindlichkeit</string>
    <string name="tooltip_iso_body">Verstärkt das Sensorsignal. ISO 100 = sauber, rauschfrei. ISO 6400+ = hell, aber verrauscht/körnig. Immer den niedrigsten möglichen ISO-Wert verwenden.</string>
    <string name="tooltip_wb_title">Weißabgleich</string>
    <string name="tooltip_wb_body">Passt die Farbtemperatur an, damit Weiß neutral wirkt. „Bewölkt" wärmt das Bild auf (~6500K). „Glühlicht" kühlt es ab (~3200K). RAW-Aufnahmen erlauben spätere Änderungen.</string>
    <string name="tooltip_focus_title">Fokusmodus</string>
    <string name="tooltip_focus_body">Einzelbild-AF (AF-S): sperrt den Fokus beim halbem Auslöserdruck — ideal für ruhige Motive. Kontinuierlicher AF (AF-C): verfolgt ein bewegtes Motiv. Manuell: präzise Fokuskontrolle durch dich.</string>

    <!-- Scenarios -->
    <string name="scenario_golden_hour_title">Porträts zur Goldenen Stunde</string>
    <string name="scenario_golden_hour_subtitle">Warmes, schmeichelhaftes Licht bei Sonnenauf-/-untergang</string>
    <string name="scenario_golden_hour_tip">Platziere das Motiv mit der Sonne dahinter für natürliches Umrisslicht. Verwende einen Reflektor, um Schatten aufzuhellen.</string>

    <string name="scenario_indoor_natural_title">Natürliches Innenlicht</string>
    <string name="scenario_indoor_natural_subtitle">Porträtsessions mit Fensterlicht</string>
    <string name="scenario_indoor_natural_tip">Stelle das Motiv in 45° zum Fenster (Rembrandt-Licht). Schalte alle künstlichen Lichter aus für saubere Farben.</string>

    <string name="scenario_studio_portrait_title">Studio-Porträts</string>
    <string name="scenario_studio_portrait_subtitle">Kontrollierte Beleuchtungsaufbauten</string>
    <string name="scenario_studio_portrait_tip">Synchronisiere den Verschluss unterhalb der Blitzsynchronzeit (meist 1/200). Beginne mit ISO 100 und passe die Blitzleistung an.</string>

    <string name="scenario_blue_hour_title">Landschaften zur Blauen Stunde</string>
    <string name="scenario_blue_hour_subtitle">Die Magie der 20–40 Min. nach Sonnenuntergang</string>
    <string name="scenario_blue_hour_tip">Verwende ein Stativ und Fernauslöser. Glühlicht-Weißabgleich verstärkt den Blauton für eine stimmungsvolle Atmosphäre.</string>

    <string name="scenario_waterfall_title">Seidige Wasserfälle</string>
    <string name="scenario_waterfall_subtitle">Wasserbewegung in Langzeitbelichtung</string>
    <string name="scenario_waterfall_tip">Bei hellem Licht ein ND-Filter verwenden. Der „Zuckerwatte"-Effekt erscheint bei Belichtungen von 1–2 Sekunden.</string>

    <string name="scenario_golden_landscape_title">Landschaften zur Goldenen Stunde</string>
    <string name="scenario_golden_landscape_subtitle">Dramatisches warmes Licht auf dem Gelände</string>
    <string name="scenario_golden_landscape_tip">30 Min. vor der Goldenen Stunde ankommen. Standorte vorher erkunden — das Licht ändert sich in Minuten.</string>

    <string name="scenario_freeze_motion_title">Schnelle Bewegungen einfrieren</string>
    <string name="scenario_freeze_motion_subtitle">Scharfe Action-Aufnahmen</string>
    <string name="scenario_freeze_motion_tip">Serienaufnahmen nutzen und Motiven folgen. KI-Tracking-AF macht hier einen riesigen Unterschied.</string>

    <string name="scenario_panning_title">Mitziehen mit Bewegungsunschärfe</string>
    <string name="scenario_panning_subtitle">Geschwindigkeitsunschärfe mit scharfem Motiv</string>
    <string name="scenario_panning_tip">Dem Motiv gleichmäßig folgen und in der Bewegung auslösen. Erfordert Übung — in Serienaufnahmen fotografieren.</string>

    <string name="scenario_sports_outdoor_title">Sport im Freien</string>
    <string name="scenario_sports_outdoor_subtitle">Tages-Feld- und Platzsport</string>
    <string name="scenario_sports_outdoor_tip">So positionieren, dass die Sonne im Rücken ist. Langes Teleobjektiv (200–600mm) für enge Bildausschnitte verwenden.</string>

    <string name="scenario_milky_way_title">Milchstraße</string>
    <string name="scenario_milky_way_subtitle">Galaxienkern in klaren Nächten</string>
    <string name="scenario_milky_way_tip">Die „500er-Regel" verwenden — 500 durch Brennweite = maximale Sekunden, bevor Strichspuren erscheinen.</string>

    <string name="scenario_city_night_title">Stadt bei Nacht</string>
    <string name="scenario_city_night_subtitle">Urbane Nachtlandschaften und Lichtspuren</string>
    <string name="scenario_city_night_tip">Auf bürgerliche Dämmerung warten — Stadtlichter und blauer Himmel gleichen sich ca. 20 Min. nach Sonnenuntergang wunderschön aus.</string>

    <string name="scenario_light_painting_title">Lichtmalerei</string>
    <string name="scenario_light_painting_subtitle">Kreative Langzeitbelichtung mit Lichtquellen</string>
    <string name="scenario_light_painting_tip">Dunkle Kleidung tragen, um nicht im Bild zu erscheinen. Für Detailarbeit eine kleine Taschenlampe verwenden.</string>

    <string name="scenario_wedding_reception_title">Hochzeitsempfang</string>
    <string name="scenario_wedding_reception_subtitle">Innenveranstaltungen mit gemischtem Licht</string>
    <string name="scenario_wedding_reception_tip">Blitz von der Decke abpuffern für natürlich wirkendes Fülllicht. RAW aufnehmen — gemischtes Licht ist schwer in der Kamera zu treffen.</string>

    <string name="scenario_concert_title">Konzert und Live-Musik</string>
    <string name="scenario_concert_subtitle">Bühnenlicht, schnelle Performer</string>
    <string name="scenario_concert_tip">Die meisten Venues erlauben Kameras nur für die ersten 3 Songs. Die Beleuchtung beim Soundcheck erkunden.</string>

    <string name="scenario_corporate_title">Firmenveranstaltungen</string>
    <string name="scenario_corporate_subtitle">Konferenzen, Porträts, Podiumsdiskussionen</string>
    <string name="scenario_corporate_tip">Bilder schnell liefern — Kunden brauchen oft noch am selben Tag Social-Media-Posts. Vor Ort konsequent aussortieren.</string>

    <string name="scenario_sunny_street_title">Straße an einem Sonnentag</string>
    <string name="scenario_sunny_street_subtitle">Helle urbane Tageslichtfotografie</string>
    <string name="scenario_sunny_street_tip">Sunny-16-Regel: bei f/16 an sonnigen Tagen ist Verschlusszeit = 1/ISO. „Zonenfokus" nutzen, um aus der Hüfte zu fotografieren.</string>

    <string name="scenario_rainy_street_title">Straße an einem Regentag</string>
    <string name="scenario_rainy_street_subtitle">Reflexionen und stimmungsvolle nasse Szenen</string>
    <string name="scenario_rainy_street_tip">Tief fotografieren, um Pfützenreflexionen einzufangen. Bewölktes Licht ist von Natur aus weich — ideal für Straßenfarben.</string>

    <string name="scenario_night_street_title">Straße bei Nacht</string>
    <string name="scenario_night_street_subtitle">Neonlichter, Bars und städtisches Nachtleben</string>
    <string name="scenario_night_street_tip">Das Korn akzeptieren. Hohes ISO-Rauschen bei Nacht wirkt kinematografisch — für die Lichter belichten, nicht für die Schatten.</string>

