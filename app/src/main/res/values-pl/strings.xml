    <!-- Tooltips -->
    <string name="tooltip_aperture_title">Przysłona (f-stop)</string>
    <string name="tooltip_aperture_body">Kontroluje głębię ostrości i ilość wpadającego światła. Małe liczby f (f/1.4) = szeroko otwarta = płytka głębia + więcej światła. Duże liczby (f/16) = małe otwarcie = duża głębia + mniej światła.</string>
    <string name="tooltip_shutter_title">Czas naświetlania</string>
    <string name="tooltip_shutter_body">Jak długo sensor jest eksponowany. Szybkie czasy (1/1000s) zamrażają ruch. Wolne (1/30s) tworzą rozmycie. Poniżej 1/60s z ręki powoduje poruszenie — użyj statywu.</string>
    <string name="tooltip_iso_title">Czułość ISO</string>
    <string name="tooltip_iso_body">Wzmacnia sygnał sensora. ISO 100 = czyste, bez szumów. ISO 6400+ = jasne, ale zaszumione/ziarniste. Zawsze używaj jak najniższego ISO, na jakie pozwala scena.</string>
    <string name="tooltip_wb_title">Balans bieli</string>
    <string name="tooltip_wb_body">Dostosowuje temperaturę barwową, by biel wyglądała neutralnie. \"Zachmurzenie\" ociepla obraz (~6500K). \"Żarówkowe\" chłodzi (~3200K). Zdjęcia RAW pozwalają zmienić to później.</string>
    <string name="tooltip_focus_title">Tryb ostrości</string>
    <string name="tooltip_focus_body">Pojedynczy AF (AF-S): blokuje ostrość przy półwciśnięciu spustu — idealny do nieruchomych obiektów. Śledzący AF (AF-C): ciągle śledzi ruchomy obiekt. Ręczny: precyzyjnie kontrolujesz ostrość.</string>

    <!-- Scenarios -->
    <string name="scenario_golden_hour_title">Portrety w Złotej Godzinie</string>
    <string name="scenario_golden_hour_subtitle">Ciepłe, pochlebne światło o wschodzie/zachodzie słońca</string>
    <string name="scenario_golden_hour_tip">Ustaw obiekt z słońcem za plecami, by uzyskać naturalne światło obrysu. Użyj reflektora do wypełnienia cieni.</string>

    <string name="scenario_indoor_natural_title">Naturalne Światło w Pomieszczeniu</string>
    <string name="scenario_indoor_natural_subtitle">Sesje portretowe z oświetleniem od okna</string>
    <string name="scenario_indoor_natural_tip">Ustaw obiekt pod kątem 45° do okna (oświetlenie Rembrandta). Wyłącz wszystkie sztuczne światła dla czystych kolorów.</string>

    <string name="scenario_studio_portrait_title">Portrety Studyjne</string>
    <string name="scenario_studio_portrait_subtitle">Kontrolowane ustawienia oświetlenia</string>
    <string name="scenario_studio_portrait_tip">Zsynchronizuj migawkę poniżej czasu synchronizacji lampy (zazwyczaj 1/200). Zacznij od ISO 100 i dostosuj moc lampy błyskowej.</string>

    <string name="scenario_blue_hour_title">Krajobrazy w Niebieskiej Godzinie</string>
    <string name="scenario_blue_hour_subtitle">Magia 20–40 minut po zachodzie słońca</string>
    <string name="scenario_blue_hour_tip">Użyj statywu i zdalnego wyzwalacza. Balans bieli żarówkowy wzmacnia niebieski odcień dla nastrojowego wyglądu.</string>

    <string name="scenario_waterfall_title">Jedwabiste Wodospady</string>
    <string name="scenario_waterfall_subtitle">Ruch wody w długim naświetlaniu</string>
    <string name="scenario_waterfall_tip">Użyj filtra ND w jasnym świetle. Efekt „waty cukrowej" pojawia się przy naświetlaniu 1–2 sekundy.</string>

    <string name="scenario_golden_landscape_title">Krajobrazy w Złotej Godzinie</string>
    <string name="scenario_golden_landscape_subtitle">Dramatyczne ciepłe światło na terenie</string>
    <string name="scenario_golden_landscape_tip">Przyjedź 30 minut przed złotą godziną. Rozpoznaj lokacje wcześniej — światło zmienia się w ciągu minut.</string>

    <string name="scenario_freeze_motion_title">Zamrażanie Szybkiego Ruchu</string>
    <string name="scenario_freeze_motion_subtitle">Ostre zdjęcia akcji</string>
    <string name="scenario_freeze_motion_tip">Używaj serii zdjęć i podążaj za ruchomymi obiektami. AF śledzenia z AI robi tu ogromną różnicę.</string>

    <string name="scenario_panning_title">Panning z Rozmyciem Ruchu</string>
    <string name="scenario_panning_subtitle">Rozmycie prędkości z ostrym obiektem</string>
    <string name="scenario_panning_tip">Płynnie śledź obiekt i naciśnij spust w połowie ruchu. Wymaga ćwiczeń — fotografuj w serii.</string>

    <string name="scenario_sports_outdoor_title">Sport na Świeżym Powietrzu</string>
    <string name="scenario_sports_outdoor_subtitle">Dzienne sporty na boisku i korcie</string>
    <string name="scenario_sports_outdoor_tip">Ustaw się tak, by słońce było za plecami. Użyj długiego teleobiektywu (200–600mm) do ciasnych ujęć.</string>

    <string name="scenario_milky_way_title">Droga Mleczna</string>
    <string name="scenario_milky_way_subtitle">Centrum galaktyki w bezchmurne noce</string>
    <string name="scenario_milky_way_tip">Użyj „reguły 500" — podziel 500 przez ogniskową = maksymalna liczba sekund przed pojawieniem się smug gwiezdnych.</string>

    <string name="scenario_city_night_title">Miasto Nocą</string>
    <string name="scenario_city_night_subtitle">Miejskie nocne pejzaże i smugi świateł</string>
    <string name="scenario_city_night_tip">Poczekaj na zmierzch cywilny — miejskie światła i niebieskie niebo pięknie się równoważą około 20 minut po zachodzie słońca.</string>

    <string name="scenario_light_painting_title">Malowanie Światłem</string>
    <string name="scenario_light_painting_subtitle">Kreatywne długie naświetlanie z narzędziami świetlnymi</string>
    <string name="scenario_light_painting_tip">Noś ciemne ubrania, by nie pojawić się na zdjęciu. Użyj małej latarki do szczegółowej pracy.</string>

    <string name="scenario_wedding_reception_title">Przyjęcie Weselne</string>
    <string name="scenario_wedding_reception_subtitle">Imprezy w pomieszczeniach z mieszanym oświetleniem</string>
    <string name="scenario_wedding_reception_tip">Odbij lampę od sufitu dla naturalnie wyglądającego wypełnienia. Fotografuj w RAW — mieszane oświetlenie trudno korygować w aparacie.</string>

    <string name="scenario_concert_title">Koncerty i Muzyka Na Żywo</string>
    <string name="scenario_concert_subtitle">Oświetlenie sceniczne, szybko poruszający się wykonawcy</string>
    <string name="scenario_concert_tip">Większość miejsc zezwala na aparaty tylko przez pierwsze 3 piosenki. Zbadaj oświetlenie podczas próby dźwięku.</string>

    <string name="scenario_corporate_title">Imprezy Firmowe</string>
    <string name="scenario_corporate_subtitle">Konferencje, zdjęcia firmowe, panele</string>
    <string name="scenario_corporate_tip">Dostarczaj zdjęcia szybko — klienci często potrzebują postów w mediach społecznościowych tego samego dnia. Agresywnie selekcjonuj zdjęcia w terenie.</string>

    <string name="scenario_sunny_street_title">Ulica w Słoneczny Dzień</string>
    <string name="scenario_sunny_street_subtitle">Fotografia miejska w jasnym świetle dziennym</string>
    <string name="scenario_sunny_street_tip">Reguła Sunny 16: w słoneczny dzień przy f/16 czas migawki = 1/ISO. Używaj „ogniskowania strefowego" do fotografowania z biodra.</string>

    <string name="scenario_rainy_street_title">Ulica w Deszczowy Dzień</string>
    <string name="scenario_rainy_street_subtitle">Odbicia i nastrojowe mokre sceny</string>
    <string name="scenario_rainy_street_tip">Fotografuj nisko, by uchwycić odbicia w kałużach. Zachmurzone światło jest naturalnie miękkie — świetne dla kolorów ulicznych.</string>

    <string name="scenario_night_street_title">Ulica Nocą</string>
    <string name="scenario_night_street_subtitle">Neony, bary i nocne miejskie życie</string>
    <string name="scenario_night_street_tip">Zaakceptuj ziarno. Wysoki szum ISO nocą daje kinematograficzny charakter — eksponuj na jasne partie, nie cienie.</string>

